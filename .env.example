# Shared
NODE_ENV=development
KESTREL_ENABLE_DEMO_MODE=true
KESTREL_DEMO_PERSONA=bfiu_analyst
NEXT_PUBLIC_ENABLE_DEMO_MODE=true
NEXT_PUBLIC_DEMO_PERSONA=bfiu_analyst

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
# Expected `aud` claim on Supabase access tokens. Leave at the default
# unless tokens come from a non-Supabase issuer; empty disables the check.
SUPABASE_JWT_AUD=authenticated

# Engine
ENGINE_PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=http://localhost:3000
STORAGE_BUCKET_UPLOADS=kestrel-uploads
STORAGE_BUCKET_EXPORTS=kestrel-exports
GOAML_SYNC_ENABLED=false
GOAML_BASE_URL=
GOAML_API_KEY=
# Operator console: comma-separated Enso operator emails allowed to see the
# cross-tenant operator surface at /platform. Empty => no access.
KESTREL_PLATFORM_OPERATORS=
# Optional per-operator role map (JSON {"email":"role"}); roles gate console
# modules. Allow-listed operators not named here default to "owner".
KESTREL_PLATFORM_OPERATOR_ROLES=

# AI Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
AI_REDACTION_MODE=redact
AI_ENABLE_EXTERNAL_PROBES=false
AI_PROVIDER_TIMEOUT_SECONDS=5
AI_FALLBACK_ENABLED=true
OPENAI_MODEL=
ANTHROPIC_MODEL=

# Web
ENGINE_URL=http://localhost:8000
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000
