# Kestrel on-prem environment.
#
# Copy to `infra/onprem/.env` (sibling of docker-compose.yml) and edit secrets.
# Compose reads this file automatically.

# --- Database -----------------------------------------------------------------
POSTGRES_DB=kestrel
POSTGRES_USER=kestrel
POSTGRES_PASSWORD=change-me-please

# --- Public hostname (Caddy) --------------------------------------------------
KESTREL_PUBLIC_HOST=kestrel.local
KESTREL_PUBLIC_ENGINE_URL=/api

# --- Auth ---------------------------------------------------------------------
# On-prem with no Supabase: leave SUPABASE_JWT_SECRET blank and set
# KESTREL_ENABLE_DEMO_MODE=true for first-boot smoke tests. Customer-side
# integration with their IdP (typically OIDC or SAML) is a Phase-6 follow-up.
SUPABASE_JWT_SECRET=
KESTREL_ENABLE_DEMO_MODE=true
NEXT_PUBLIC_ENABLE_DEMO_MODE=true

# --- AI -----------------------------------------------------------------------
# Customer's GPU box runs vLLM with the sovereign adapter loaded.
# AI_SOVEREIGN_URL points at the vLLM OpenAI-compatible endpoint.
# Leave blank to run in heuristic-only mode (adequate for STR drafting,
# entity extraction; degraded for narrative generation).
AI_SOVEREIGN_URL=
AI_SOVEREIGN_MODEL=
AI_SOVEREIGN_API_KEY=

# --- Telemetry pingback -------------------------------------------------------
# Defaults to off in air-gapped deployments. When the customer is willing to
# allow outbound for billing reconciliation, flip to true and set the URL.
KESTREL_TELEMETRY_ENABLED=false
KESTREL_TELEMETRY_URL=

# --- CORS ---------------------------------------------------------------------
ALLOWED_ORIGINS=https://kestrel.local
